# Convex deployment URL — from `npx convex dev` output or Convex dashboard
CONVEX_URL=https://your-deployment.convex.cloud

# DeepSeek API key — used by all agents for the "think" step
DEEPSEEK_API_KEY=sk-...

# Optional: override agent polling intervals (seconds)
# MONITORING_INTERVAL=30
# RAPID_RESPONSE_INTERVAL=15
# FLEET_INTERVAL=20
